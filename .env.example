# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Resend (email)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM="Event Accommodation <accommodation@yourdomain.com>"

# Twilio (SMS)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+15551234567

# Voice for all TwiML <Say> prompts. Defaults to Polly.Kajal-Neural.
# Examples: Polly.Kajal-Neural (Indian English, female, neural)
#           Polly.Joanna-Neural (American English, female, neural)
#           Polly.Matthew-Neural (American English, male, neural)
# See https://www.twilio.com/docs/voice/twiml/say/text-speech for more.
TWILIO_VOICE=Polly.Kajal-Neural

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
COORDINATOR_PASSWORD=change-me-to-something-strong
COORDINATOR_EMAIL=you@yourdomain.com
EVENT_NAME="Our Annual Event"
EVENT_DATES="Nov 15-17, 2026"

# Cron (used by Vercel scheduled outreach job)
CRON_SECRET=generate-a-random-string-for-this

# Sequential outreach configuration
# Days between each stage in the channel sequence below.
# Default: 2. Range: 1–30.
OUTREACH_STAGE_DELAY_DAYS=2

# Comma-separated list of channels to use, in order.
# Allowed values: sms, email, sms+email, voice
# Examples:
#   sms+email,sms,email,voice          (default — SMS+email together first, then SMS reminder, email reminder, voice call)
#   email,sms,email,voice              (email-first)
#   sms+email,sms,email                (skip voice — gentler approach)
#   email,email,email                  (email-only, three times)
OUTREACH_CHANNEL_SEQUENCE=sms+email,sms,email,voice
